# Safe local development defaults only.
# Do not commit real secrets in .env files.

# Metadata placeholders
SERVICE_NAME=[REPLACE_ME_SERVICE_NAME]
SERVICE_OWNER=[REPLACE_ME_TEAM_ALIAS]

# Local PostgreSQL (used by docker compose and optional scripts)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Azurite local storage emulator
AZURITE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
